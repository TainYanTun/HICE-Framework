{
    "latex-workshop.latex.recipes": [
        {
            "name": "compile-main",
            "tools": [
                "latexmk"
            ]
        }
    ],
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk",
            "command": "/Library/TeX/texbin/latexmk",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-pdf",
                "-g",
                "-outdir=%DIR%",
                "-auxdir=%DIR%",
                "%DOC%"
            ],
            "env": {
                "PATH": "/Library/TeX/texbin:/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin"
            }
        }
    ],
    "latex-workshop.latex.recipe.default": "compile-main",
    "latex-workshop.latex.rootFile.indicator": "% !TEX root",
    "latex-workshop.latex.search.rootFiles.include": [
        "research/main.tex"
    ],
    "latex-workshop.view.pdf.viewer": "tab",
    "latex-workshop.formatting.latex": "none",
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python3"
}
